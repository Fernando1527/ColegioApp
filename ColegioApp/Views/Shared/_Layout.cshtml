<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ColegioApp</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ColegioApp.styles.css" asp-append-version="true" />

    <style>
        body {
            background-color: #f5f7fa;
        }

        .navbar {
            background-color: #0d6efd !important;
        }

        .navbar .nav-link,
        .navbar .navbar-brand {
            color: white !important;
            font-weight: 500;
        }

        .navbar .nav-link:hover {
            text-decoration: underline;
        }

        footer {
            text-align: center;
            padding: 10px;
        }
    </style>
</head>

<body>

    <!-- 🔥 NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm">
            <div class="container-fluid">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    🎓 ColegioApp
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Alumnos" asp-action="Index">Alumnos</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Materias" asp-action="Index">Materias</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Expedientes" asp-action="Index">Expedientes</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Expedientes" asp-action="Promedios">Promedios</a>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- CONTENIDO -->
    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="border-top text-muted mt-4">
        <div class="container">
            © 2026 - ColegioApp | Sistema de Gestión Escolar
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>